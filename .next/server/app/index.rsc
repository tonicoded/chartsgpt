}a:T139c,<div class="home-shell home-shell-v2">
      <header class="site-header site-header-home" aria-label="Site header">
        <div class="site-header-inner">
          <a class="site-brand" href="./" aria-label="ChartsGPT Home">
            <img src="./logo.png" alt="ChartsGPT logo" width="36" height="36" loading="eager" />
            <span>ChartsGPT</span>
          </a>
          <nav class="site-nav" aria-label="Primary">
            <a href="./blog/">Blog</a>
            <a href="./about/">About</a>
            <a href="./support/">Support</a>
          </nav>
          <details class="blog-menu">
            <summary aria-label="Open menu"><span class="blog-menu-icon" aria-hidden="true"></span></summary>
            <div class="blog-menu-panel" role="menu" aria-label="Menu">
              <a role="menuitem" href="./">Home</a>
              <a role="menuitem" href="./blog/">Blog</a>
              <a role="menuitem" href="./about/">About</a>
              <a role="menuitem" href="./privacy/">Privacy</a>
              <a role="menuitem" href="./terms/">Terms</a>
              <a role="menuitem" href="./support/">Support</a>
            </div>
          </details>
        </div>
      </header>

      <main class="landing landing-home" aria-label="ChartsGPT landing page">
        <section class="hero-v2" aria-label="Hero">
          <div class="container hero-v2-grid">
            <div class="hero-v2-copy reveal" style="--delay: 60ms">
              <div class="hero-v2-trust">
                <span class="hero-v2-trust-stars">★★★★★</span>
                <span>4.8 on the App Store</span>
              </div>
              <h1 class="hero-v2-title">Scan a chart. Get the trade plan.</h1>
              <p class="hero-v2-sub">
                Key levels, bias, entry, stop loss, and invalidation from one screenshot.
              </p>
            </div>

            <div class="hero-v2-stage reveal" style="--delay: 160ms" aria-label="Product preview">
              <div class="stage-phone stage-phone-main">
                <img src="/6.5_02.jpg" alt="ChartsGPT analysis screen with chart and assistant output" loading="eager" />
              </div>
              <div class="stage-phone stage-phone-left">
                <img src="/6.5_01.jpg" alt="ChartsGPT camera capture flow" loading="lazy" />
              </div>
              <div class="stage-phone stage-phone-right">
                <img src="/6.5_03.jpg" alt="ChartsGPT risk and entry view" loading="lazy" />
              </div>
            </div>

            <div class="hero-v2-cta-row reveal" style="--delay: 220ms">
              <a
                class="store-badge store-badge-hero js-appstore"
                href="https://apps.apple.com/nl/app/chartsgpt-ai-trading-assist/id6758857719?l=en-GB"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="Download ChartsGPT on the App Store"
              >
                <img src="./appstore.svg" alt="Download on the App Store" />
              </a>
              <button class="store-badge store-badge-hero store-badge-static gp-trigger" aria-label="Google Play — coming soon" type="button">
                <img src="./googleplay.svg" alt="Get it on Google Play" />
              </button>
            </div>
          </div>
        </section>
      </main>
    </div>

    <dialog class="gp-modal" id="gp-modal">
      <div class="gp-modal-inner">
        <div class="gp-modal-top">
          <svg class="gp-modal-logo" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M3 20.5v-17c0-.83 1-.83 1.5-.5L20 12 4.5 21c-.5.33-1.5.33-1.5-.5Z" fill="url(#gp-grad)"/>
            <defs><linearGradient id="gp-grad" x1="3" y1="3.5" x2="20" y2="12" gradientUnits="userSpaceOnUse"><stop stop-color="#34d17a"/><stop offset="1" stop-color="#22c55e" stop-opacity=".7"/></linearGradient></defs>
          </svg>
          <button class="gp-modal-close" onclick="document.getElementById('gp-modal').close()" aria-label="Close">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </div>
        <h3 class="gp-modal-title">Android is on its way</h3>
        <p class="gp-modal-text">We're actively building the Android version. ChartsGPT is currently available on iOS.</p>
        <a class="gp-modal-btn js-appstore" href="https://apps.apple.com/nl/app/chartsgpt-ai-trading-assist/id6758857719?l=en-GB" target="_blank" rel="noopener noreferrer">
          Download on iOS instead
        </a>
      </div>
    </dialog>

    <script>
      document.querySelector('.gp-trigger').addEventListener('click', function () {
        document.getElementById('gp-modal').showModal();
      });
      document.getElementById('gp-modal').addEventListener('click', function (e) {
        if (e.target === this) this.close();
      });
    </script>2:["$","div",null,{"className":"home-body home-v2","suppressHydrationWarning":true,"children":[[["$","script","jsonld-0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$9"}}]],["$","div",null,{"dangerouslySetInnerHTML":{"__html":"$a"}}]]}]
