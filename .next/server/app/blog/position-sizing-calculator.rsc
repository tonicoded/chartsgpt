    </div>

    <script>
      (() => {
        const form = document.getElementById("calc");
        const calcBtn = document.getElementById("calcBtn");
        const resetBtn = document.getElementById("resetBtn");
        const riskOut = document.getElementById("riskOut");
        const sizeOut = document.getElementById("sizeOut");

        const fmtMoney = (n) =>
          new Intl.NumberFormat(undefined, { style: "currency", currency: "USD", maximumFractionDigits: 2 }).format(n);
        const fmtNum = (n) => new Intl.NumberFormat(undefined, { maximumFractionDigits: 6 }).format(n);

        const read = (name) => Number(form.elements[name].value || 0);
        const calc = () => {
          const account = Math.max(0, read("account"));
          const riskPct = Math.max(0, read("risk_pct"));
          const stop = Math.max(0, read("stop"));
          const riskAmount = account * (riskPct / 100);
          const positionSize = stop > 0 ? riskAmount / stop : 0;
          riskOut.textContent = fmtMoney(riskAmount);
          sizeOut.textContent = fmtNum(positionSize);
        };

        calcBtn.addEventListener("click", calc);
        resetBtn.addEventListener("click", () => {
          form.elements.account.value = 10000;
          form.elements.risk_pct.value = 1;
          form.elements.stop.value = 50;
          calc();
        });
        calc();
      })();
    </script>2:["$","div",null,{"className":"legacy-scroll blog-body","suppressHydrationWarning":true,"children":[[["$","script","jsonld-0",{"type":"application/ld+json","dangerouslySetInnerHTML":{"__html":"$9"}}]],["$","div",null,{"dangerouslySetInnerHTML":{"__html":"$a"}}]]}]
